{
  "mcpServers": {
    "choir": {
      "type": "stdio",
      "command": "choir",
      "args": [
        "mcp-stdio",
        "--role",
        "dev",
        "--name",
        "main.gemini-project-mcp-0"
      ]
    }
  },
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "choir hook worker-exit --runtime gemini"
          }
        ]
      }
    ]
  }
}