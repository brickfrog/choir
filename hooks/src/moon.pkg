import {
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/json",
}

options(
  targets: {
    "extism_abi.mbt": [ "wasm" ],
    "extism_abi_stub.mbt": [ "wasm-gc" ],
  },
  link: {
    "wasm": {
      "exports": [ "before_model", "after_model", "pre_tool_use" ],
      "export-memory-name": "memory",
    },
    "wasm-gc": {
      "exports": [ "before_model", "after_model", "pre_tool_use" ],
      "export-memory-name": "memory",
    },
  },
)
