#!/usr/bin/env bash
set -euo pipefail

# Collect staged .mbt files for moon fmt. Include renames (R) so
# renamed-and-touched .mbt files still get formatted.
staged="$(git diff --cached --name-only)"
staged_mbt=()
while IFS= read -r f; do
  [ -n "$f" ] && staged_mbt+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.mbt')

echo "→ moon fmt (staged .mbt files only)"
if [ "${#staged_mbt[@]}" -gt 0 ]; then
  moon fmt -- "${staged_mbt[@]}"
else
  echo "  (no staged .mbt files; skipping)"
fi

if [ -n "$staged" ]; then
  while IFS= read -r f; do
    if [ -e "$f" ] && ! git check-ignore -q "$f" 2>/dev/null; then
      git add -- "$f"
    fi
  done <<EOF
$staged
EOF
fi

echo "→ moon check --target native"
moon check --target native
