#!/usr/bin/env bash
set -euo pipefail

echo "→ moon fmt"
staged="$(git diff --cached --name-only)"
moon fmt

if [ -n "$staged" ]; then
  while IFS= read -r f; do
    if [ -e "$f" ] && ! git check-ignore -q "$f" 2>/dev/null; then
      git add -- "$f"
    fi
  done <<EOF
$staged
EOF
fi

echo "→ lint canary (moon-fmt corruption guard)"
staged_mbt="$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.mbt$' || true)"
if [ -n "$staged_mbt" ]; then
  if ! tools/lint_canary.sh $staged_mbt; then
    echo
    echo "ERROR: moon fmt produced choir_lint-incompatible syntax."
    echo "  Either revert the affected lines, or wait for moonbitlang/parser to ship a fn-accepting grammar (see choir-p8w6)."
    exit 1
  fi
fi

echo "→ moon check --target native"
moon check --target native
